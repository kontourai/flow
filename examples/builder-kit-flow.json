{
  "id": "builder-kit-flow",
  "version": "1",
  "steps": [
    { "id": "shape", "next": "plan" },
    { "id": "plan", "next": "implement" },
    { "id": "implement", "next": "verify" },
    { "id": "verify", "next": "merge-ready" },
    { "id": "merge-ready", "next": null }
  ],
  "gates": {
    "shape-gate": {
      "step": "shape",
      "requires": ["problem-framing"]
    },
    "plan-gate": {
      "step": "plan",
      "expects": [
        {
          "id": "acceptance-shaped",
          "kind": "surface.claim",
          "required": true,
          "description": "Acceptance criteria are explicit enough for implementation.",
          "claim": {
            "type": "builder.acceptance",
            "subject": "builder.plan",
            "accepted_statuses": ["trusted", "reviewed"]
          }
        }
      ]
    },
    "verify-gate": {
      "step": "verify",
      "expects": [
        {
          "id": "tests-passed",
          "kind": "surface.claim",
          "required": true,
          "description": "Targeted tests passed.",
          "claim": {
            "type": "quality.tests",
            "subject": "builder.verify",
            "accepted_statuses": ["trusted"]
          }
        },
        {
          "id": "browser-evidence-reviewed",
          "kind": "surface.claim",
          "required": false,
          "description": "Browser evidence was reviewed when applicable.",
          "explore_hint": "Optional for non-UI changes.",
          "claim": {
            "type": "quality.browser-evidence",
            "subject": "builder.verify",
            "accepted_statuses": ["trusted"]
          }
        }
      ],
      "on_route_back": {
        "missing_evidence": "verify",
        "implementation_defect": "implement",
        "plan_gap": "plan",
        "decision_gap": "shape",
        "default": "implement"
      },
      "route_back_policy": {
        "max_attempts": 2,
        "on_exceeded": "merge-ready"
      }
    }
  }
}
