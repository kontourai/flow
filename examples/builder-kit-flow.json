{
  "id": "builder-kit-flow",
  "version": "2",
  "steps": [
    { "id": "shape", "next": "plan" },
    { "id": "plan", "next": "implement" },
    { "id": "implement", "next": "verify" },
    { "id": "verify", "next": "merge-ready" },
    { "id": "merge-ready", "next": null }
  ],
  "gates": {
    "shape-gate": {
      "step": "shape",
      "expects": [
        {
          "id": "problem-framing",
          "kind": "trust.bundle",
          "required": true,
          "description": "Problem framing is explicit enough to plan.",
          "bundle_claim": {
            "claimType": "builder.problem-framing",
            "subjectType": "flow-step",
            "subjectId": "builder.shape",
            "accepted_statuses": ["verified", "assumed"]
          }
        }
      ]
    },
    "plan-gate": {
      "step": "plan",
      "expects": [
        {
          "id": "acceptance-shaped",
          "kind": "trust.bundle",
          "required": true,
          "description": "Acceptance criteria are explicit enough for implementation.",
          "bundle_claim": {
            "claimType": "builder.acceptance",
            "subjectType": "flow-step",
            "subjectId": "builder.plan",
            "accepted_statuses": ["verified", "assumed"]
          }
        }
      ]
    },
    "verify-gate": {
      "step": "verify",
      "expects": [
        {
          "id": "tests-passed",
          "kind": "trust.bundle",
          "required": true,
          "description": "Targeted tests passed.",
          "bundle_claim": {
            "claimType": "quality.tests",
            "subjectType": "flow-step",
            "subjectId": "builder.verify",
            "accepted_statuses": ["verified"]
          }
        },
        {
          "id": "browser-evidence-reviewed",
          "kind": "trust.bundle",
          "required": false,
          "description": "Browser evidence was reviewed when applicable.",
          "explore_hint": "Optional for non-UI changes.",
          "bundle_claim": {
            "claimType": "quality.browser-evidence",
            "subjectType": "flow-step",
            "subjectId": "builder.verify",
            "accepted_statuses": ["verified"]
          }
        }
      ],
      "on_route_back": {
        "missing_evidence": "verify",
        "implementation_defect": "implement",
        "plan_gap": "plan",
        "decision_gap": "shape",
        "default": "implement"
      },
      "route_back_policy": {
        "max_attempts": 2,
        "on_exceeded": "merge-ready"
      }
    }
  }
}
