{
  "id": "trust-bundle-fixture-flow",
  "version": "2",
  "steps": [
    { "id": "plan", "next": "verify" },
    { "id": "verify", "next": "publish" },
    { "id": "publish", "next": null }
  ],
  "gates": {
    "verify-gate": {
      "step": "verify",
      "expects": [
        {
          "id": "tests-passed",
          "kind": "trust.bundle",
          "required": true,
          "description": "Tests passed for the verify step.",
          "bundle_claim": {
            "claimType": "quality.tests",
            "subjectType": "flow-step",
            "subjectId": "builder.verify",
            "accepted_statuses": ["verified"]
          }
        }
      ],
      "on_route_back": {
        "missing_evidence": "verify",
        "default": "plan"
      },
      "route_back_policy": {
        "max_attempts": 2,
        "on_exceeded": "block"
      }
    }
  }
}
