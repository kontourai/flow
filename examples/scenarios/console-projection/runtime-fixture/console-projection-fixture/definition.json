{
  "id": "console-projection-flow",
  "version": "0.1",
  "title": "Console projection fixture",
  "description": "Hand-authored fixture for the Flow Console projection read model.",
  "steps": [
    {
      "id": "shape",
      "label": "Shape",
      "next": "build"
    },
    {
      "id": "build",
      "label": "Build",
      "next": "verify"
    },
    {
      "id": "verify",
      "label": "Verify",
      "next": "release"
    },
    {
      "id": "release",
      "label": "Release",
      "next": null
    }
  ],
  "gates": {
    "build-gate": {
      "step": "build",
      "expects": [
        {
          "id": "missing-review",
          "kind": "trust.bundle",
          "required": true,
          "description": "Reviewer approval is attached.",
          "bundle_claim": {
            "claimType": "human.review",
            "subjectType": "flow-step",
            "subjectId": "console-projection-fixture",
            "accepted_statuses": ["verified"]
          }
        }
      ]
    },
    "verify-gate": {
      "step": "verify",
      "expects": [
        {
          "id": "tests-passed",
          "kind": "trust.bundle",
          "required": true,
          "description": "Tests passed through Hachure trust bundle.",
          "bundle_claim": {
            "claimType": "quality.tests",
            "subjectType": "flow-step",
            "subjectId": "console-projection-fixture",
            "accepted_statuses": ["verified"]
          }
        }
      ],
      "on_route_back": {
        "implementation_defect": "build",
        "default": "build"
      },
      "route_back_policy": {
        "max_attempts": 2,
        "on_exceeded": "block"
      }
    }
  }
}
