{
  "id": "adversarial-pass-flow",
  "version": "2",
  "steps": [
    { "id": "produce", "next": "adversarial-review" },
    { "id": "adversarial-review", "next": "resolve" },
    { "id": "resolve", "next": null }
  ],
  "gates": {
    "adversarial-review-gate": {
      "step": "adversarial-review",
      "expects": [
        {
          "id": "producer-output-claim",
          "kind": "trust.bundle",
          "required": true,
          "description": "The producer output under adversarial review is available as trusted evidence.",
          "bundle_claim": {
            "claimType": "adversarial.producer-output",
            "subjectType": "flow-step",
            "subjectId": "adversarial-pass.produce",
            "accepted_statuses": ["verified"]
          }
        },
        {
          "id": "adversarial-review-claim",
          "kind": "trust.bundle",
          "required": true,
          "description": "The adversarial review result is recorded as trusted per-round evidence.",
          "bundle_claim": {
            "claimType": "adversarial.review",
            "subjectType": "flow-step",
            "subjectId": "adversarial-pass.review",
            "accepted_statuses": ["verified"]
          }
        }
      ],
      "on_route_back": {
        "conclusion_defect": "produce",
        "framing_defect": "produce",
        "completeness_defect": "produce",
        "citation_defect": "resolve",
        "missing_evidence": "adversarial-review",
        "default": "resolve"
      },
      "route_back_policy": {
        "max_attempts": 2,
        "on_exceeded": "block"
      }
    },
    "resolve-gate": {
      "step": "resolve",
      "expects": [
        {
          "id": "resolution-claim",
          "kind": "trust.bundle",
          "required": true,
          "description": "The resolved output addresses the adversarial review findings.",
          "bundle_claim": {
            "claimType": "adversarial.resolution",
            "subjectType": "flow-step",
            "subjectId": "adversarial-pass.resolve",
            "accepted_statuses": ["verified"]
          }
        }
      ]
    }
  }
}
