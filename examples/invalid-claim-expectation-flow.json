{
  "id": "invalid-claim-expectation-flow",
  "version": "1",
  "steps": [
    { "id": "plan", "next": "verify" },
    { "id": "verify", "next": null }
  ],
  "gates": {
    "verify-gate": {
      "step": "verify",
      "expects": [
        {
          "id": "missing-bundle-claim",
          "kind": "trust.bundle",
          "required": true,
          "description": "This entry is missing bundle_claim."
        },
        {
          "id": "missing-claim-type",
          "kind": "trust.bundle",
          "required": true,
          "description": "This entry is missing bundle_claim.claimType.",
          "bundle_claim": {
            "subjectType": "flow-step",
            "accepted_statuses": ["verified"]
          }
        },
        {
          "id": "bad-accepted-statuses",
          "kind": "trust.bundle",
          "required": false,
          "description": "This entry has malformed accepted statuses.",
          "bundle_claim": {
            "claimType": "quality.tests",
            "accepted_statuses": []
          }
        },
        {
          "id": "bad-kind",
          "kind": "surface-claim",
          "required": true,
          "description": "This entry uses an unsupported kind.",
          "bundle_claim": {
            "claimType": "quality.tests"
          }
        }
      ],
      "on_route_back": {
        "implementation_defect": "missing-step"
      },
      "route_back_policy": {
        "max_attempts": 1,
        "on_exceeded": "missing-recovery"
      }
    }
  }
}
