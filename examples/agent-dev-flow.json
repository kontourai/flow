{
  "id": "agent-dev-flow",
  "version": "1",
  "steps": [
    { "id": "plan", "next": "implement" },
    { "id": "implement", "next": "verify" },
    { "id": "verify", "next": "publish" },
    { "id": "publish", "next": null }
  ],
  "gates": {
    "plan-gate": { "step": "plan", "requires": ["acceptance-criteria"] },
    "implement-gate": { "step": "implement", "requires": ["scoped-diff"] },
    "verify-gate": { "step": "verify", "requires": ["tests", "lint", "browser-evidence", "veritas-readiness"] }
  }
}
