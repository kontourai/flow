{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src/console-ui",
    "outDir": "dist/console-ui",
    "strict": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["src/console-ui/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
