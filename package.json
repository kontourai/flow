{
  "name": "@kontourai/flow",
  "version": "0.1.0",
  "description": "Process transparency for agentic work.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "flow": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "schemas/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test scripts/check-schemas.mjs scripts/check-repo-hooks.mjs",
    "check:schemas": "node scripts/check-schemas.mjs",
    "check:repo-hooks": "node --test scripts/check-repo-hooks.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.mjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.mjs",
    "prepack": "npm test && npm run check:schemas"
  },
  "keywords": [
    "agents",
    "workflow",
    "process-transparency",
    "evidence"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/flow.git"
  }
}
