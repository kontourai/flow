{
  "name": "@kontourai/flow",
  "version": "0.1.5",
  "description": "Process transparency for agentic work.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "flow": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./console-projection": {
      "types": "./dist/console-projection.d.ts",
      "import": "./dist/console-projection.js",
      "default": "./dist/console-projection.js"
    },
    "./console-server": {
      "types": "./dist/console-server.d.ts",
      "import": "./dist/console-server.js",
      "default": "./dist/console-server.js"
    }
  },
  "files": [
    "dist/",
    "schemas/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/sync-console-kit-assets.mjs && tsc && tsc -p tsconfig.console-ui.json && node scripts/copy-console-ui.mjs",
    "test": "npm run build && node --test scripts/check-schemas.mjs scripts/check-repo-hooks.mjs scripts/check-console-projection.mjs && node scripts/check-console-smoke.mjs && npm run test:browser",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:console-ui": "tsc -p tsconfig.console-ui.json --noEmit",
    "sync:console-kit": "node scripts/sync-console-kit-assets.mjs",
    "check:console-kit-assets": "node scripts/sync-console-kit-assets.mjs --check",
    "check:console-smoke": "npm run build && node scripts/check-console-smoke.mjs",
    "check:schemas": "npm run build && node scripts/check-schemas.mjs",
    "check:repo-hooks": "node --test scripts/check-repo-hooks.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.mjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.mjs",
    "prepack": "npm run typecheck && npm test"
  },
  "keywords": [
    "agents",
    "workflow",
    "process-transparency",
    "evidence"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/flow.git"
  },
  "devDependencies": {
    "@kontourai/console-kit": "^0.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  }
}
