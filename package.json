{
  "name": "@kontourai/flow",
  "version": "0.1.0",
  "description": "Process transparency for agentic work.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "flow": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "schemas/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test scripts/check-schemas.mjs scripts/check-repo-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "check:schemas": "npm run build && node scripts/check-schemas.mjs",
    "check:repo-hooks": "node --test scripts/check-repo-hooks.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.mjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.mjs",
    "prepack": "npm run typecheck && npm test"
  },
  "keywords": [
    "agents",
    "workflow",
    "process-transparency",
    "evidence"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/flow.git"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
