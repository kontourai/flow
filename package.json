{
  "name": "@kontourai/flow",
  "version": "1.2.0",
  "description": "Process transparency for agentic work.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "flow": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "!dist/console-projection.*",
    "!dist/console-server.*",
    "!dist/flow-files.*",
    "schemas/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/sync-ui-assets.mjs && tsc && tsc -p tsconfig.console-ui.json && node scripts/copy-console-ui.mjs",
    "test": "npm run build && npm run check:types:contracts && node --test tests/node/*.test.mjs && node scripts/check-console-smoke.mjs && npm run test:browser",
    "test:node": "node --test tests/node/*.test.mjs",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:types:contracts": "tsc -p tsconfig.types.json --noEmit",
    "typecheck:console-ui": "tsc -p tsconfig.console-ui.json --noEmit",
    "docs:build": "node scripts/docs-site/build.ts",
    "docs:check": "npm run docs:build && node scripts/docs-site/check-links.ts",
    "sync:ui": "node scripts/sync-ui-assets.mjs",
    "check:ui-assets": "node scripts/sync-ui-assets.mjs --check",
    "check:console-smoke": "npm run build && node scripts/check-console-smoke.mjs",
    "check:schemas": "npm run build && npm run test:node",
    "check:console-projection": "npm run build && node --test tests/node/check-console-projection.test.mjs",
    "check:package-contents": "npm run build && node --test tests/node/check-package-contents.test.mjs",
    "check:repo-hooks": "node --test tests/node/check-repo-hooks.test.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.mjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.mjs",
    "prepack": "npm run typecheck && npm test"
  },
  "keywords": [
    "agents",
    "ai-agents",
    "workflow",
    "process-transparency",
    "evidence",
    "gates",
    "audit-trail",
    "claude-code",
    "ci"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/flow.git"
  },
  "devDependencies": {
    "@kontourai/ui": "^1.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "marked": "^16.4.2",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@kontourai/surface": "^1.0.1",
    "ajv": "^8.20.0",
    "hachure": "^0.4.0"
  }
}
