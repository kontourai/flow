{
  "name": "@kontourai/flow",
  "version": "3.8.0",
  "description": "Process transparency for agentic work.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "flow": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./console-contract": {
      "types": "./dist/console/console-contract.d.ts",
      "import": "./dist/console/console-contract.js",
      "default": "./dist/console/console-contract.js"
    },
    "./flow-run-panel/element": {
      "import": "./dist/console-ui/flow-run-panel.js",
      "default": "./dist/console-ui/flow-run-panel.js"
    },
    "./flow-run-panel/standalone.css": "./dist/console-ui/flow-run-panel.css"
  },
  "files": [
    "dist/",
    "!dist/console-projection.*",
    "!dist/console-server.*",
    "!dist/flow-files.*",
    "schemas/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/with-build-lease.mjs npm run test:locked",
    "test:locked": "npm run build && npm run check:types:contracts && node --test tests/node/*.test.mjs && node scripts/check-console-smoke.mjs && npm run test:browser:locked",
    "test:node": "node scripts/with-build-lease.mjs npm run test:node:locked",
    "test:node:locked": "node --test tests/node/*.test.mjs",
    "test:browser": "node scripts/with-build-lease.mjs npm run test:browser:locked",
    "test:browser:locked": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:types:contracts": "tsc -p tsconfig.types.json --noEmit",
    "typecheck:console-ui": "tsc -p tsconfig.console-ui.json --noEmit",
    "docs:build": "node scripts/docs-site/build.ts",
    "docs:check": "npm run docs:build && node scripts/docs-site/check-links.ts && npm run check:decisions",
    "check:decisions": "node scripts/check-decisions.cjs check",
    "gen:decisions-index": "node scripts/check-decisions.cjs gen-index",
    "freeze:adrs": "node scripts/freeze-adrs.mjs",
    "sync:ui": "node scripts/sync-ui-assets.mjs",
    "check:ui-assets": "node scripts/sync-ui-assets.mjs --check",
    "check:console-smoke": "node scripts/with-build-lease.mjs npm run check:console-smoke:locked",
    "check:console-smoke:locked": "npm run build && node scripts/check-console-smoke.mjs",
    "check:schemas": "node scripts/with-build-lease.mjs npm run check:schemas:locked",
    "check:schemas:locked": "npm run build && npm run test:node:locked",
    "check:console-projection": "node scripts/with-build-lease.mjs npm run check:console-projection:locked",
    "check:console-projection:locked": "npm run build && node --test tests/node/check-console-projection.test.mjs",
    "check:package-contents": "node scripts/with-build-lease.mjs npm run check:package-contents:locked",
    "check:package-contents:locked": "npm run build && node --test tests/node/check-package-contents.test.mjs",
    "check:repo-hooks": "node scripts/with-build-lease.mjs npm run check:repo-hooks:locked",
    "check:repo-hooks:locked": "node --test tests/node/check-repo-hooks.test.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.mjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.mjs",
    "prepack": "npm run typecheck && npm test"
  },
  "trust-reconcile-manifest": [
    {
      "id": "active-definition-amendment-focused",
      "command": "node --test tests/node/check-flow-run-definition-amendment.test.mjs tests/node/check-cli-runtime.test.mjs tests/node/check-repo-hooks.test.mjs"
    }
  ],
  "keywords": [
    "agents",
    "ai-agents",
    "workflow",
    "process-transparency",
    "evidence",
    "gates",
    "audit-trail",
    "claude-code",
    "ci"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/flow.git"
  },
  "devDependencies": {
    "@kontourai/ui": "^1.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "marked": "^16.4.2",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@kontourai/surface": "^2.12.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "hachure": "^0.15.0"
  }
}
