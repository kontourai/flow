{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-report.schema.json",
  "title": "Flow Report",
  "type": "object",
  "required": ["schema_version", "state_head", "run_id", "definition_id", "status", "summary", "current_step", "gate_summaries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "state_head": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 binding to the authoritative persisted Flow Run state represented by this projection." },
    "run_id": { "type": "string" },
    "definition_id": { "type": "string" },
    "definition_version": { "type": "string" },
    "subject": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "blocked", "needs_decision", "completed", "failed", "accepted_by_exception"]
    },
    "summary": { "type": "string" },
    "current_step": { "type": "string" },
    "next_action": { "type": "string" },
    "continuation": { "type": "string" },
    "retry_authorizations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["blocked_transition_ref", "prior_run_head", "gate_id", "target_step", "prior_retry_epoch", "retry_epoch", "max_attempts", "consumed_attempts", "next_attempt", "remaining_attempts", "budget_status", "authority", "reason", "invalidated_steps", "at"],
        "additionalProperties": false,
        "properties": {
          "blocked_transition_ref": { "type": "string" },
          "prior_run_head": { "type": "string" },
          "gate_id": { "type": "string" },
          "route_reason": { "type": "string" },
          "target_step": { "type": "string" },
          "prior_retry_epoch": { "type": "integer", "minimum": 1 },
          "retry_epoch": { "type": "integer", "minimum": 1 },
          "max_attempts": { "type": "integer", "minimum": 1 },
          "consumed_attempts": { "type": "integer", "minimum": 0 },
          "next_attempt": { "type": ["integer", "null"], "minimum": 1 },
          "remaining_attempts": { "type": "integer", "minimum": 0 },
          "budget_status": { "type": "string", "enum": ["current", "historical"] },
          "authority": { "type": "object" },
          "reason": { "type": "string" },
          "invalidated_steps": { "type": "array", "items": { "type": "string" } },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "open_gates": { "type": "array", "items": { "type": "string" } },
    "accepted_exceptions": { "type": "array", "items": { "type": "object" } },
    "gate_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "status", "summary", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "gate_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "block", "route-back", "wait"] },
          "summary": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "route_back_to": { "type": "string" },
          "selected_route": { "type": "string" },
          "recovery_step": { "type": "string" },
          "route_reason": { "type": "string" },
          "attempt": { "type": "integer", "minimum": 1 },
          "retry_epoch": { "type": "integer", "minimum": 1 },
          "max_attempts": { "type": "integer", "minimum": 1 },
          "limit_exceeded": { "type": "boolean" },
          "expectation_ids": { "type": "array", "items": { "type": "string" } },
          "classifier": { "type": "object", "additionalProperties": true },
          "diagnostics": { "type": "object", "additionalProperties": true },
          "analytics": { "type": "object", "additionalProperties": true },
          "analytics_loop_key": { "type": "string" },
          "missing": { "type": "array", "items": { "type": "string" } },
          "optional_missing": { "type": "array", "items": { "type": "string" } },
          "matched_expectations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["expectation_id", "evidence_id"],
              "additionalProperties": false,
              "properties": {
                "expectation_id": { "type": "string" },
                "evidence_id": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
