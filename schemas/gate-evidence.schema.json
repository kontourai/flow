{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/gate-evidence.schema.json",
  "title": "Gate Evidence Manifest",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["id", "gate_id", "kind", "requested_kind", "status", "attached_at"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "gate_id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["command", "file", "ci", "surface.claim", "veritas-readiness", "human-attestation", "trace-link", "custom"]
        },
        "requested_kind": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "unknown"] },
        "claim": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "subject": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "producer": { "type": "string" },
        "authority_trace": { "type": "string" },
        "route_reason": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "expectation_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "classifier": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "kind": { "type": "string" },
            "source": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": true
        },
        "analytics": {
          "type": "object",
          "additionalProperties": true
        },
        "original_path": { "type": "string" },
        "stored_path": { "type": "string" },
        "sha256": { "type": "string" },
        "attached_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
