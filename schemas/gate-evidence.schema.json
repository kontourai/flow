{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/gate-evidence.schema.json",
  "title": "Gate Evidence Manifest",
  "description": "Metadata for gate evidence entries. When generated under .flow/runs/<run-id>/evidence/manifest.json, the manifest carries local run and definition identity; standalone scenario manifests may omit that identity. This is not an authored Resource Contract.",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "definition_id": { "type": "string", "minLength": 1 },
    "definition_version": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["id", "gate_id", "kind", "requested_kind", "status", "attached_at"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "gate_id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["command", "file", "ci", "surface.claim", "veritas-readiness", "human-attestation", "trace-link", "custom"]
        },
        "requested_kind": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "unknown"] },
        "claim": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "status"],
          "properties": {
            "type": { "type": "string" },
            "subject": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "trust_artifact": {
          "type": "object",
          "required": ["schema_version", "artifact_type", "claims"],
          "additionalProperties": false,
          "properties": {
            "schema_version": { "type": "string" },
            "artifact_type": { "type": "string", "enum": ["trust-report", "trust-snapshot"] },
            "subject": { "type": "string" },
            "producer": { "type": "string" },
            "status": { "type": "string" },
            "issued_at": { "type": "string", "format": "date-time" },
            "expires_at": { "type": "string", "format": "date-time" },
            "authority_traces": { "type": "array", "items": { "type": "string" } },
            "claims": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type"],
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string" },
                  "subject": { "type": "string" },
                  "status": { "type": "string" },
                  "producer": { "type": "string" },
                  "issued_at": { "type": "string", "format": "date-time" },
                  "expires_at": { "type": "string", "format": "date-time" },
                  "authority_traces": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "integrity": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sha256": { "type": "string" },
                "verified": { "type": "boolean" }
              }
            }
          }
        },
        "producer": { "type": "string" },
        "authority_trace": { "type": "string" },
        "authority_traces": { "type": "array", "items": { "type": "string" } },
        "route_reason": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "expectation_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "classifier": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "kind": { "type": "string" },
            "source": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": true
        },
        "analytics": {
          "type": "object",
          "additionalProperties": true
        },
        "original_path": { "type": "string" },
        "stored_path": { "type": "string" },
        "sha256": { "type": "string" },
        "attached_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
