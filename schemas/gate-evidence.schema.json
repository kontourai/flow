{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/gate-evidence.schema.json",
  "title": "Gate Evidence Manifest",
  "description": "Metadata for gate evidence entries. When generated under .kontourai/flow/runs/<run-id>/evidence/manifest.json, the manifest carries local run and definition identity; standalone scenario manifests may omit that identity. This is not an authored Resource Contract.",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "definition_id": { "type": "string", "minLength": 1 },
    "definition_version": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["id", "gate_id", "kind", "requested_kind", "status", "attached_at"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "gate_id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["command", "file", "ci", "trust.bundle", "veritas-readiness", "human-attestation", "trace-link", "custom"]
        },
        "requested_kind": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "unknown"] },
        "bundle": {
          "type": "object",
          "description": "A Hachure-format TrustBundle using a schema version accepted by the installed Surface validator. Present on trust.bundle evidence entries.",
          "additionalProperties": true,
          "required": ["schemaVersion", "source", "claims", "evidence", "policies", "events"],
          "properties": {
            "schemaVersion": { "enum": [5, 6, 7] },
            "source": { "type": "string" },
            "claims": { "type": "array", "items": { "type": "object" } },
            "evidence": { "type": "array", "items": { "type": "object" } },
            "policies": { "type": "array", "items": { "type": "object" } },
            "events": { "type": "array", "items": { "type": "object" } }
          }
        },
        "bundle_report": {
          "type": "object",
          "description": "Surface TrustReport derived from the attached bundle (derived claim statuses).",
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string" },
            "generatedAt": { "type": "string", "format": "date-time" },
            "claims": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "claimType": { "type": "string" },
                  "subjectType": { "type": "string" },
                  "subjectId": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            },
            "summary": { "type": "object" }
          }
        },
        "producer": { "type": "string" },
        "authority_trace": { "type": "string" },
        "authority_traces": { "type": "array", "items": { "type": "string" } },
        "route_reason": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "expectation_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "classifier": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "kind": { "type": "string" },
            "source": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": true
        },
        "analytics": {
          "type": "object",
          "additionalProperties": true
        },
        "original_path": { "type": "string" },
        "stored_path": { "type": "string" },
        "sha256": { "type": "string" },
        "attached_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
