{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/release-readiness-policy.schema.json",
  "title": "Release Readiness Policy",
  "type": "object",
  "required": ["schema_version", "id", "lanes", "risk_classes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "id": { "type": "string" },
    "description": { "type": "string" },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane" }
    },
    "risk_classes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/risk_class_policy" }
    }
  },
  "$defs": {
    "lane": {
      "type": "object",
      "required": ["id", "description", "claim"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "description": { "type": "string" },
        "adapter_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "claim": {
          "type": "object",
          "required": ["type"],
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "subject": { "type": "string" },
            "accepted_statuses": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "risk_class_policy": {
      "type": "object",
      "required": ["required_lanes"],
      "additionalProperties": true,
      "properties": {
        "required_lanes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "uniqueItems": true
        }
      }
    }
  }
}
