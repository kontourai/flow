{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-definition.schema.json",
  "title": "Flow Definition",
  "type": "object",
  "required": ["id", "version", "steps", "gates"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "version": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "gates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/gate" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "next"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "next": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
            { "type": "null" }
          ]
        }
      }
    },
    "gate": {
      "type": "object",
      "required": ["step"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "expects": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "on_route_back": {
          "type": "object",
          "propertyNames": {
            "anyOf": [
              { "const": "default" },
              { "pattern": "^[a-z0-9][a-z0-9._-]*$" }
            ]
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          }
        },
        "route_back_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1 },
            "on_exceeded": {
              "type": "string",
              "pattern": "^(block|[a-z0-9][a-z0-9._-]*)$"
            },
            "allow_unknown_reasons": { "type": "boolean" }
          }
        }
      }
    },
    "expectation": {
      "type": "object",
      "required": ["id", "kind", "required", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "kind": { "type": "string", "const": "surface.claim" },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 },
        "explore_hint": { "type": "string", "minLength": 1 },
        "claim": { "$ref": "#/$defs/surface_claim_expectation" }
      },
      "if": {
        "properties": { "kind": { "const": "surface.claim" } },
        "required": ["kind"]
      },
      "then": { "required": ["claim"] }
    },
    "surface_claim_expectation": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "examples": ["builder.shape", "builder.plan", "builder.verify", "builder.merge-ready"]
        },
        "accepted_statuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
