{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontour.ai/schemas/flow-definition.schema.json",
  "title": "Flow Definition",
  "type": "object",
  "required": ["schema_version", "id", "name", "steps"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "terminal_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate"
          }
        },
        "next": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "gate": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence_provider": {
          "type": "string"
        },
        "on_pass": {
          "type": "string"
        },
        "on_fail": {
          "type": "string"
        },
        "on_missing": {
          "type": "string"
        }
      }
    }
  }
}
