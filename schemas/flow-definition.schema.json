{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-definition.schema.json",
  "title": "Flow Definition",
  "type": "object",
  "required": ["id", "version", "steps", "gates"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "version": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "gates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/gate" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "next"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "next": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
            { "type": "null" }
          ]
        }
      }
    },
    "gate": {
      "type": "object",
      "required": ["step", "requires"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
