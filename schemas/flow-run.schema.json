{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-run.schema.json",
  "title": "Flow Run",
  "type": "object",
  "required": ["schema_version", "run_id", "definition_id", "status", "current_step", "gate_outcomes", "transitions", "exceptions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "definition_id": { "type": "string", "minLength": 1 },
    "definition_version": { "type": "string" },
    "subject": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "blocked", "needs_decision", "completed", "failed", "accepted_by_exception"]
    },
    "current_step": { "type": "string" },
    "params": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "next_action": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "gate_outcomes": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate_outcome" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition" }
    },
    "exceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/exception" }
    }
  },
  "$defs": {
    "gate_outcome": {
      "type": "object",
      "required": ["gate_id", "status", "summary", "evidence_refs"],
      "additionalProperties": true,
      "properties": {
        "gate_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pass", "block", "route-back", "wait"] },
        "summary": { "type": "string" },
        "missing": { "type": "array", "items": { "type": "string" } },
        "optional_missing": { "type": "array", "items": { "type": "string" } },
        "matched_expectations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["expectation_id", "evidence_id"],
            "additionalProperties": false,
            "properties": {
              "expectation_id": { "type": "string" },
              "evidence_id": { "type": "string" }
            }
          }
        },
        "route_back_to": { "type": "string" },
        "selected_route": { "type": "string" },
        "recovery_step": { "type": "string" },
        "route_reason": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "limit_exceeded": { "type": "boolean" },
        "expectation_ids": { "type": "array", "items": { "type": "string" } },
        "classifier": { "type": "object", "additionalProperties": true },
        "diagnostics": { "type": "object", "additionalProperties": true },
        "analytics": { "type": "object", "additionalProperties": true },
        "analytics_loop_key": { "type": "string" },
        "accepted_exception_id": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "transition": {
      "type": "object",
      "required": ["from_step", "status", "reason", "at"],
      "additionalProperties": true,
      "properties": {
        "from_step": { "type": "string" },
        "to_step": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["allowed", "blocked", "skipped", "accepted_by_exception"] },
        "type": { "type": "string" },
        "reason": { "type": "string" },
        "gate_id": { "type": "string" },
        "route_reason": { "type": "string" },
        "selected_route": { "type": "string" },
        "recovery_step": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "limit_exceeded": { "type": "boolean" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "expectation_ids": { "type": "array", "items": { "type": "string" } },
        "classifier": { "type": "object", "additionalProperties": true },
        "diagnostics": { "type": "object", "additionalProperties": true },
        "analytics": { "type": "object", "additionalProperties": true },
        "analytics_loop_key": { "type": "string" },
        "at": { "type": "string", "format": "date-time" }
      }
    },
    "exception": {
      "type": "object",
      "required": ["id", "gate_id", "reason", "authority", "accepted_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "gate_id": { "type": "string" },
        "reason": { "type": "string" },
        "authority": { "type": "string" },
        "accepted_at": { "type": "string", "format": "date-time" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
