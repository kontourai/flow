{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-run.schema.json",
  "title": "Flow Run State",
  "description": "Flat v0.1 runtime state persisted at .kontourai/flow/runs/<run-id>/state.json. This file is the authoritative continuation state for a local Flow Run; reports and console projections are derived from it plus the run definition snapshot and evidence manifest. It is not a Resource Contract envelope.",
  "type": "object",
  "required": ["schema_version", "run_id", "definition_id", "status", "current_step", "gate_outcomes", "transitions", "exceptions"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["paused", "canceled"] } }, "required": ["status"] },
      "then": {
        "required": ["lifecycle"],
        "properties": { "lifecycle": { "minItems": 1 } }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1",
      "description": "Flow schema version for this flat run-state contract."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Local run directory id from the canonical .kontourai/flow/runs/<run-id>/ path."
    },
    "definition_id": {
      "type": "string",
      "minLength": 1,
      "description": "Flow Definition id captured in definition.json when the run started."
    },
    "definition_version": {
      "type": "string",
      "description": "Flow Definition version captured in definition.json when the run started."
    },
    "subject": {
      "type": "string",
      "description": "Human or tool-facing process subject for the run."
    },
    "status": {
      "type": "string",
      "description": "Current lifecycle status for continuation and reporting.",
      "enum": ["active", "blocked", "needs_decision", "paused", "canceled", "completed", "failed", "accepted_by_exception"]
    },
    "current_step": {
      "type": "string",
      "description": "Current Flow Definition step id; open gates are derived from this step."
    },
    "params": {
      "type": "object",
      "description": "Run parameters captured at start time.",
      "additionalProperties": { "type": "string" }
    },
    "next_action": {
      "type": "string",
      "description": "One-line continuation instruction for the next operator or agent."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last state update timestamp."
    },
    "gate_outcomes": {
      "type": "array",
      "description": "Persisted gate decisions that explain why the run advanced, blocked, waited, routed back, or accepted an exception.",
      "items": { "$ref": "#/$defs/gate_outcome" }
    },
    "transitions": {
      "type": "array",
      "description": "Persisted transition history used for continuation, reporting, and route-back attempt counting.",
      "items": { "$ref": "#/$defs/transition" }
    },
    "pending_gate_rechecks": {
      "type": "array",
      "description": "Freshness-triggered checks for previously passed gates that must be revisited when the run cursor is again downstream of that gate.",
      "items": {
        "type": "object",
        "required": ["gate_id", "evidence_id", "claimId", "from", "to"],
        "additionalProperties": false,
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "evidence_id": { "type": "string", "minLength": 1 },
          "claimId": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lifecycle": {
      "type": "array",
      "description": "Separate pause, resume, and cancellation history. Absence on a legacy run is normalized to an empty array when loaded; lifecycle records never count as Step transitions.",
      "items": { "$ref": "#/$defs/lifecycle_event" }
    },
    "exceptions": {
      "type": "array",
      "description": "Accepted exceptions with explicit reason and authority.",
      "items": { "$ref": "#/$defs/exception" }
    }
  },
  "$defs": {
    "lifecycle_authority": {
      "type": "object",
      "required": ["kind", "actor", "request_ref", "requested_at"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["user_request", "operator_request"] },
        "actor": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" },
        "request_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$",
          "description": "Immutable provider-neutral reference to the externally authenticated request."
        },
        "requested_at": { "type": "string", "format": "date-time" }
      }
    },
    "lifecycle_event": {
      "type": "object",
      "required": ["action", "from_status", "to_status", "prior_status", "reason", "authority", "at"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "enum": ["pause", "resume", "cancel"] },
        "from_status": { "$ref": "#/$defs/run_status" },
        "to_status": { "$ref": "#/$defs/run_status" },
        "prior_status": {
          "type": "string",
          "enum": ["active", "blocked", "needs_decision"],
          "description": "The exact resumable status captured by pause and restored by resume; cancellation records the resumable status when one exists."
        },
        "reason": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" },
        "authority": { "$ref": "#/$defs/lifecycle_authority" },
        "at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "pause" } }, "required": ["action"] },
          "then": {
            "properties": {
              "from_status": { "enum": ["active", "blocked", "needs_decision"] },
              "to_status": { "const": "paused" }
            }
          }
        },
        {
          "if": { "properties": { "action": { "const": "resume" } }, "required": ["action"] },
          "then": {
            "properties": {
              "from_status": { "const": "paused" },
              "to_status": { "enum": ["active", "blocked", "needs_decision"] }
            }
          }
        },
        {
          "if": { "properties": { "action": { "const": "cancel" } }, "required": ["action"] },
          "then": {
            "properties": {
              "from_status": { "enum": ["active", "blocked", "needs_decision", "paused"] },
              "to_status": { "const": "canceled" }
            }
          }
        }
      ]
    },
    "run_status": {
      "type": "string",
      "enum": ["active", "blocked", "needs_decision", "paused", "canceled", "completed", "failed", "accepted_by_exception"]
    },
    "gate_outcome": {
      "type": "object",
      "required": ["gate_id", "status", "summary", "evidence_refs"],
      "additionalProperties": true,
      "properties": {
        "gate_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pass", "block", "route-back", "wait"] },
        "summary": { "type": "string" },
        "missing": { "type": "array", "items": { "type": "string" } },
        "optional_missing": { "type": "array", "items": { "type": "string" } },
        "matched_expectations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["expectation_id", "evidence_id"],
            "additionalProperties": false,
            "properties": {
              "expectation_id": { "type": "string" },
              "evidence_id": { "type": "string" }
            }
          }
        },
        "route_back_to": { "type": "string" },
        "selected_route": { "type": "string" },
        "recovery_step": { "type": "string" },
        "route_reason": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "limit_exceeded": { "type": "boolean" },
        "expectation_ids": { "type": "array", "items": { "type": "string" } },
        "classifier": { "type": "object", "additionalProperties": true },
        "diagnostics": { "type": "object", "additionalProperties": true },
        "analytics": { "type": "object", "additionalProperties": true },
        "analytics_loop_key": { "type": "string" },
        "accepted_exception_id": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "transition": {
      "type": "object",
      "required": ["from_step", "status", "reason", "at"],
      "additionalProperties": true,
      "properties": {
        "from_step": { "type": "string" },
        "to_step": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["allowed", "blocked", "skipped", "accepted_by_exception"] },
        "type": { "type": "string" },
        "reason": { "type": "string" },
        "gate_id": { "type": ["string", "null"] },
        "route_reason": { "type": "string" },
        "selected_route": { "type": "string" },
        "recovery_step": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "limit_exceeded": { "type": "boolean" },
        "invalidated_steps": { "type": "array", "items": { "type": "string" }, "description": "Steps whose gate outcomes were cleared by the route-back cascade (descendants of the route-back target)." },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "expectation_ids": { "type": "array", "items": { "type": "string" } },
        "classifier": { "type": "object", "additionalProperties": true },
        "diagnostics": { "type": "object", "additionalProperties": true },
        "analytics": { "type": "object", "additionalProperties": true },
        "analytics_loop_key": { "type": "string" },
        "freshness_transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/freshness_transition" }
        },
        "at": { "type": "string", "format": "date-time" }
      }
    },
    "freshness_transition": {
      "type": "object",
      "required": ["gate_id", "evidence_id", "claimId", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "gate_id": { "type": "string", "minLength": 1 },
        "evidence_id": { "type": "string", "minLength": 1 },
        "claimId": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "exception": {
      "type": "object",
      "required": ["id", "gate_id", "reason", "authority", "accepted_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "gate_id": { "type": "string" },
        "reason": { "type": "string" },
        "authority": { "type": "string" },
        "accepted_at": { "type": "string", "format": "date-time" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
