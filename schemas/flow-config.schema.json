{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/flow-config.schema.json",
  "title": "Flow Project Config",
  "type": "object",
  "required": ["schema_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "trusted_producers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/trusted_producer_mapping" }
    },
    "gate_overrides": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/gate_override" }
    }
  },
  "$defs": {
    "trusted_producer_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "producers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "authority_traces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "gate_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expectations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/expectation_override" }
        }
      }
    },
    "expectation_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "accepted_statuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "trusted_producers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "authority_traces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
